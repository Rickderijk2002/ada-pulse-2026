# Copy this file to .env and fill in the values
#
# AUTHENTICATION — use GCP Application Default Credentials (ADC), same as the ADA labs.
# Before running for the first time:
#   gcloud auth application-default login
#
# This tells google-adk / google-genai to use your local GCP credentials
# instead of an AI Studio API key.

# Route Gemini calls through Vertex AI (uses ADC — no API key needed)
GOOGLE_GENAI_USE_VERTEXAI=true

# GCP project that hosts Vertex AI + Pub/Sub
GOOGLE_CLOUD_PROJECT=ada26-pulse-project

# URL of the KPI MCP server
# Local development: http://localhost:8080/mcp
# Cloud Run: https://pulse-kpi-serving-<hash>.run.app/mcp
KPI_MCP_URL=http://localhost:8080/mcp

# Pub/Sub topic to publish insights-ready events (Step 5)
INSIGHTS_READY_TOPIC=insights-ready
